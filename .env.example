# ==============================================================
# KingsWorld — variáveis de ambiente
# ==============================================================
# Copiar para .env.local e preencher com os valores reais.
# NUNCA commitar .env.local no git.

# --- Supabase (obrigatório — Vercel + local) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# --- Capacitor (build Android) ---
CAPACITOR_APP_ID=com.kingsworld.app
CAPACITOR_APP_NAME=KingsWorld
CAPACITOR_SERVER_URL=https://your-deployed-kingsworld.vercel.app

# --- Runtime ---
KINGSWORLD_RUNTIME_GAME_DAY_MS=86400000

# ==============================================================
# O que NÃO vai aqui (e onde fica):
#
# Google Play Billing secrets (GOOGLE_PLAY_PACKAGE_NAME,
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON) → Supabase secrets
#   npx supabase secrets set ... --project-ref <ref>
#
# IDs de produto (premium_monthly, monthly) → hardcoded em
#   lib/premium-config.ts (igual ao padrão GOL)
#
# Vercel não precisa de nenhuma var de billing.
# ==============================================================
